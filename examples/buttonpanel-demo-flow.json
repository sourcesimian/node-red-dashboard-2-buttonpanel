    {
        "id": "demo-initial-values",
        "type": "function",
        "z": "buttonpanel-demo-tab",
        "name": "init",
        "func": "const image = imageValue('LOGO');\nconst iframe = iframeValue('STATUS');\n\nreturn [\n    { payload: 'AUTO' },\n    { payload: 'OFF' },\n    { payload: 'MOUNTAIN' },\n    { payload: 35 },\n    { payload: 20 },\n    { payload: 72 },\n    { payload: 'OFF' },\n    { payload: image },\n    { payload: image },\n    { payload: iframe },\n    { payload: 'Ready' },\n    { enabled: false }\n];\n\nfunction imageValue(value) {\n    const images = {\n        LOGO: { title: 'BUTTONPANEL', subtitle: 'image value', color: '#52D017', symbol: '<path d=\"M70 80h32M86 64v32\" stroke=\"#172015\" stroke-width=\"10\" stroke-linecap=\"round\"/>' },\n        ALERT: { title: 'ALERT', subtitle: 'selected image', color: '#f89406', symbol: '<path d=\"M86 54l38 66H48z\" fill=\"#23180a\"/><rect x=\"82\" y=\"74\" width=\"8\" height=\"24\" fill=\"#f89406\"/><circle cx=\"86\" cy=\"108\" r=\"4\" fill=\"#f89406\"/>' }\n    };\n    const item = images[value] || images.LOGO;\n    const svg = [\n        '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"360\" height=\"160\" viewBox=\"0 0 360 160\">',\n        '<rect width=\"360\" height=\"160\" fill=\"#20262b\"/>',\n        '<rect x=\"18\" y=\"18\" width=\"324\" height=\"124\" rx=\"8\" fill=\"#303940\"/>',\n        '<circle cx=\"86\" cy=\"80\" r=\"42\" fill=\"' + item.color + '\"/>',\n        item.symbol,\n        '<text x=\"150\" y=\"72\" fill=\"#f5f5f5\" font-family=\"Arial\" font-size=\"28\" font-weight=\"700\">' + item.title + '</text>',\n        '<text x=\"150\" y=\"106\" fill=\"#bdbdbd\" font-family=\"Arial\" font-size=\"18\">' + item.subtitle + '</text>',\n        '</svg>'\n    ].join('');\n    return 'data:image/svg+xml;charset=utf-8,' + encodeURIComponent(svg);\n}\n\nfunction iframeValue(value) {\n    const panels = {\n        STATUS: { title: 'Iframe', detail: 'value driven panel', color: '#52D017' },\n        METRICS: { title: 'Metrics', detail: 'selected iframe content', color: '#26c6da' }\n    };\n    const panel = panels[value] || panels.STATUS;\n    const html = [\n        '<!doctype html><html><head><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>html,body{margin:0;min-height:100%;background:#32383e;color:#f5f5f5;font:16px Arial;}body{box-sizing:border-box;display:flex;align-items:center;justify-content:center;padding:12px;text-align:center;}</style></head><body>',\n        '<div><strong style=\"color:' + panel.color + '\">' + panel.title + '</strong><br><span style=\"color:#bdbdbd\">' + panel.detail + '</span></div>',\n        '</body></html>'\n    ].join('');\n    return 'data:text/html;charset=utf-8,' + encodeURIComponent(html);\n}",
        "outputs": 12,
        "timeout": 0,
        "noerr": 0,
